PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/beaconai
API_BASE_URL=http://localhost:4000/api
WEB_BASE_URL=http://localhost:5173
TOKEN_ENCRYPTION_SECRET=replace_with_a_long_random_secret

# Optional local fallback for a single test store. Production installs should use OAuth.
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_CLIENT_ID=shopify_oauth_client_id
SHOPIFY_CLIENT_SECRET=shopify_oauth_client_secret
SHOPIFY_SCOPES=read_products,read_customers,read_orders,write_orders

# Optional local fallback for a single test Klaviyo account. Production installs should use OAuth.
KLAVIYO_PRIVATE_KEY=
KLAVIYO_REVISION=2026-04-15
KLAVIYO_CLIENT_ID=klaviyo_oauth_client_id
KLAVIYO_CLIENT_SECRET=klaviyo_oauth_client_secret
KLAVIYO_SCOPES=accounts:read campaigns:read campaigns:write catalogs:read flows:read lists:write profiles:read profiles:write segments:read templates:read templates:write
