<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>{{ brand }} — Growth Roadmap • {{ story.hero.month_label }}</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@700&display=swap');

    :root {
      --beacon-navy: #0F172A;
      --beacon-blue: #3B82F6;
      --beacon-amber: #F59E0B;
      --beacon-success: #10B981;
      --beacon-warning: #FBBF24;
      --beacon-error: #EF4444;
      --beacon-gray-900: #111827;
      --beacon-gray-700: #374151;
      --beacon-gray-600: #4B5563;
      --beacon-gray-400: #9CA3AF;
      --beacon-gray-300: #D1D5DB;
      --beacon-gray-200: #E5E7EB;
      --beacon-gray-100: #F3F4F6;
      --beacon-gray-50: #F9FAFB;
      --beacon-white: #FFFFFF;
      --font-primary: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      background: var(--beacon-gray-50);
      font-family: var(--font-primary);
      color: var(--beacon-gray-900);
    }

    .demo-container {
      max-width: 1180px;
      margin: 0 auto;
      background: var(--beacon-white);
      min-height: 100vh;
      box-shadow: 0 20px 60px rgba(15, 23, 42, 0.08);
    }

    section {
      padding: 56px 72px;
      border-bottom: 1px solid var(--beacon-gray-100);
    }

    .hero, .next-steps {
      position: relative;
      overflow: hidden;
      background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    }

    .hero::before, .next-steps::before {
      content: '';
      position: absolute;
      inset: -40% -20% -20% -40%;
      background: radial-gradient(circle at 20% 30%, rgba(245, 158, 11, 0.18) 0%, transparent 55%),
                  radial-gradient(circle at 80% 25%, rgba(59, 130, 246, 0.20) 0%, transparent 52%),
                  radial-gradient(circle at 45% 80%, rgba(16, 185, 129, 0.16) 0%, transparent 60%);
      filter: blur(28px);
      pointer-events: none;
    }

    .hero::after, .next-steps::after {
      content: '';
      position: absolute;
      inset: -60% -40% -40% -60%;
      background: linear-gradient(135deg, transparent 45%, rgba(245, 158, 11, 0.25) 50%, transparent 55%);
      opacity: 0.6;
      pointer-events: none;
    }

    .hero > *, .next-steps > * { position: relative; z-index: 1; }

    .brand-lockup {
      display: inline-flex;
      align-items: center;
      gap: 14px;
      flex-wrap: wrap;
    }

    .brand-wordmark {
        font-family: 'Space Grotesk', 'Inter', sans-serif;
        font-weight: 700;
        font-size: 30px;
        letter-spacing: -0.06em;
        color: var(--beacon-navy);
        text-transform: lowercase;
        display: inline-flex;
        align-items: center;
    }

    .brand-dot {
      color: var(--beacon-amber);
      display: inline-block;
      margin: 0 2px;
    }

    .brand-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-left: 16px;
      padding: 6px 14px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      background: rgba(59, 130, 246, 0.12);
      color: var(--beacon-blue);
    }

    .hero h1 {
      margin: 24px 0 12px;
      font-size: 40px;
      font-weight: 700;
      line-height: 1.1;
      color: var(--beacon-navy);
    }

    .hero-subheadline {
      margin: 0 0 32px;
      font-size: 18px;
      color: var(--beacon-gray-600);
      max-width: 640px;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 20px;
    }

    .hero-card {
      background: rgba(255, 255, 255, 0.92);
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: 16px;
      padding: 24px;
      box-shadow: 0 18px 40px rgba(15, 23, 42, 0.06);
      backdrop-filter: blur(6px);
    }

    .hero-card h3 {
      margin: 0 0 6px;
      font-size: 14px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--beacon-blue);
    }

    .hero-value {
      font-size: 24px;
      font-weight: 800;
      margin-bottom: 8px;
      color: var(--beacon-navy);
    }

    .hero-note {
      margin: 0;
      font-size: 15px;
      color: var(--beacon-gray-600);
      line-height: 1.6;
    }

    .section-kicker {
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--beacon-blue);
      margin-bottom: 12px;
    }

    /* Seasonal Callout Banner */
    .seasonal-banner {
      margin: 0;
      padding: 20px 72px;
      background: linear-gradient(135deg, rgba(251, 191, 36, 0.12) 0%, rgba(245, 158, 11, 0.08) 100%);
      border-bottom: 1px solid rgba(245, 158, 11, 0.2);
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .seasonal-banner.type-elevated {
      background: linear-gradient(135deg, rgba(251, 191, 36, 0.12) 0%, rgba(245, 158, 11, 0.08) 100%);
      border-bottom-color: rgba(245, 158, 11, 0.2);
    }

    .seasonal-banner.type-depressed {
      background: linear-gradient(135deg, rgba(59, 130, 246, 0.08) 0%, rgba(59, 130, 246, 0.04) 100%);
      border-bottom-color: rgba(59, 130, 246, 0.2);
    }

    .seasonal-banner.type-mixed {
      background: linear-gradient(135deg, rgba(139, 92, 246, 0.08) 0%, rgba(139, 92, 246, 0.04) 100%);
      border-bottom-color: rgba(139, 92, 246, 0.2);
    }

    .seasonal-icon {
      font-size: 24px;
      flex-shrink: 0;
    }

    .seasonal-content {
      flex: 1;
    }

    .seasonal-title {
      font-size: 14px;
      font-weight: 700;
      color: var(--beacon-amber);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 4px;
    }

    .seasonal-message {
      font-size: 14px;
      color: var(--beacon-gray-700);
      line-height: 1.5;
      margin: 0;
    }

    .section-title {
      margin: 0;
      font-size: 32px;
      font-weight: 700;
    }

    .section-title .title-accent {
      font-size: 16px;
      font-weight: 600;
      color: var(--beacon-blue);
      margin-left: 12px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .section-summary {
      margin: 10px 0 36px;
      font-size: 17px;
      color: var(--beacon-gray-600);
      line-height: 1.6;
      max-width: 720px;
    }

    .score-section {
      background: linear-gradient(135deg, #F9FAFB 0%, #F3F4F6 100%);
    }

    .score-layout {
      display: grid;
      grid-template-columns: 320px 1fr;
      gap: 32px;
      align-items: start;
    }

    .score-card {
      background: var(--beacon-white);
      border-radius: 20px;
      padding: 32px;
      box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
      border: 1px solid var(--beacon-gray-100);
    }

    .score-value {
      display: flex;
      align-items: baseline;
      gap: 16px;
    }

    .score-number {
      font-size: 64px;
      font-weight: 800;
      color: var(--beacon-navy);
    }

    .score-tier {
      font-size: 16px;
      font-weight: 600;
      background: rgba(16, 185, 129, 0.12);
      color: var(--beacon-success);
      padding: 6px 14px;
      border-radius: 999px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .score-trend {
      margin-top: 8px;
      font-size: 14px;
      font-weight: 600;
      color: var(--beacon-blue);
    }

    .score-summary-card {
      margin-top: 18px;
      padding: 18px;
      border-radius: 12px;
      background: rgba(59, 130, 246, 0.08);
      border: 1px solid rgba(59, 130, 246, 0.15);
      font-size: 15px;
      color: var(--beacon-gray-700);
      line-height: 1.6;
    }

    .score-factors {
      display: grid;
      gap: 18px;
    }

    .factor-card {
      display: grid;
      grid-template-columns: 180px 1fr;
      gap: 20px;
      background: var(--beacon-white);
      border-radius: 16px;
      padding: 24px;
      border: 1px solid var(--beacon-gray-100);
      box-shadow: 0 8px 22px rgba(15, 23, 42, 0.06);
    }

    .factor-metric {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .factor-name {
      font-size: 14px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--beacon-gray-500);
      font-weight: 600;
    }

    .factor-score {
      font-size: 32px;
      font-weight: 700;
      color: var(--beacon-navy);
    }

    .factor-story {
      font-size: 15px;
      color: var(--beacon-gray-600);
      line-height: 1.6;
    }

    .chart-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 24px;
    }

    .chart-card {
      background: var(--beacon-white);
      border-radius: 18px;
      padding: 24px;
      border: 1px solid var(--beacon-gray-100);
      box-shadow: 0 12px 28px rgba(15, 23, 42, 0.06);
      display: flex;
      flex-direction: column;
      gap: 18px;
    }

    .chart-tag {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 12px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.06em;
      background: rgba(59, 130, 246, 0.12);
      color: var(--beacon-blue);
      text-transform: uppercase;
    }

    .chart-figure {
      background: linear-gradient(135deg, rgba(59, 130, 246, 0.06), rgba(59, 130, 246, 0.12));
      border-radius: 14px;
      padding: 12px;
    }

    .chart-figure img { width: 100%; border-radius: 12px; display: block; }

    .chart-caption {
      font-size: 15px;
      color: var(--beacon-gray-600);
      line-height: 1.6;
    }

    .actions-section {
      background: linear-gradient(180deg, #FFFFFF 0%, #F8FAFC 100%);
    }

    .tier-section {
      margin-bottom: 48px;
      display: grid;
      gap: 24px;
      padding: 32px;
      border-radius: 24px;
      border: 1px solid var(--beacon-gray-100);
      background: var(--beacon-white);
      box-shadow: 0 10px 40px rgba(15, 23, 42, 0.06);
    }

    .tier-section.primary {
      background: linear-gradient(180deg, rgba(59, 130, 246, 0.08) 0%, rgba(59, 130, 246, 0.03) 100%);
      border-color: rgba(59, 130, 246, 0.25);
    }

    .tier-section.quick_wins {
      background: linear-gradient(180deg, rgba(245, 158, 11, 0.10) 0%, rgba(245, 158, 11, 0.04) 100%);
      border-color: rgba(245, 158, 11, 0.25);
    }

    .tier-section.experiments {
      background: linear-gradient(180deg, rgba(99, 102, 241, 0.12) 0%, rgba(99, 102, 241, 0.05) 100%);
      border-color: rgba(99, 102, 241, 0.25);
    }

    .tier-section.watchlist {
      background: linear-gradient(180deg, rgba(15, 23, 42, 0.08) 0%, rgba(15, 23, 42, 0.03) 100%);
      border-color: rgba(15, 23, 42, 0.18);
    }

    .tier-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }

    .tier-title {
      margin: 0;
      font-size: 22px;
      font-weight: 700;
      color: var(--beacon-navy);
    }

    .tier-pill {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      padding: 6px 12px;
      border-radius: 999px;
      font-weight: 700;
      background: rgba(59, 130, 246, 0.18);
      color: var(--beacon-blue);
    }

    .tier-pill.primary { background: rgba(59, 130, 246, 0.18); color: var(--beacon-blue); }
    .tier-pill.quick_wins { background: rgba(245, 158, 11, 0.18); color: var(--beacon-amber); }
    .tier-pill.experiments { background: rgba(99, 102, 241, 0.20); color: #4338CA; }
    .tier-pill.watchlist { background: rgba(15, 23, 42, 0.16); color: var(--beacon-gray-700); }

    .tier-description {
      margin: 0;
      font-size: 15px;
      color: var(--beacon-gray-600);
    }

    .actions-grid {
      display: grid;
      gap: 28px;
    }

    .action-card {
      background: var(--beacon-white);
      border-radius: 20px;
      border: 1px solid var(--beacon-gray-100);
      padding: 32px;
      box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    .action-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 18px;
      gap: 24px;
    }

    .action-title {
      margin: 0;
      font-size: 26px;
      font-weight: 700;
      color: var(--beacon-navy);
    }

    .signal-badge {
      padding: 5px 12px;
      border-radius: 6px;
      font-weight: 600;
      font-size: 12px;
      text-transform: capitalize;
    }

    .signal-badge.strong-signal {
      background: rgba(16, 185, 129, 0.12);
      color: var(--beacon-success);
    }

    .signal-badge.moderate-signal {
      background: rgba(245, 158, 11, 0.12);
      color: var(--beacon-amber);
    }

    .signal-badge.weak-signal {
      background: rgba(107, 114, 128, 0.12);
      color: var(--beacon-gray-600);
    }

    .signal-badge.signal-pending {
      background: var(--beacon-gray-100);
      color: var(--beacon-gray-500);
    }

    .tier-reason {
      margin: 8px 0 12px;
      padding: 10px 14px;
      background: linear-gradient(135deg, rgba(59, 130, 246, 0.06) 0%, rgba(16, 185, 129, 0.06) 100%);
      border-left: 3px solid var(--beacon-blue);
      border-radius: 0 8px 8px 0;
      font-size: 14px;
      font-weight: 500;
      color: var(--beacon-gray-700);
      line-height: 1.4;
    }

    .action-metrics {
      display: flex;
      gap: 18px;
      font-size: 14px;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      font-weight: 600;
      color: var(--beacon-gray-500);
    }

    .action-metrics span strong {
      display: block;
      font-size: 20px;
      margin-top: 4px;
      color: var(--beacon-navy);
      text-transform: none;
      letter-spacing: normal;
    }

    .action-narrative {
      font-size: 16px;
      color: var(--beacon-gray-700);
      line-height: 1.7;
      margin: 16px 0 22px;
    }

    /* NEW: Why Now - one-liner tied to chart */
    .why-now {
      margin: 12px 0 20px;
      padding: 14px 18px;
      background: linear-gradient(135deg, rgba(59, 130, 246, 0.08) 0%, rgba(59, 130, 246, 0.04) 100%);
      border-left: 3px solid var(--beacon-blue);
      border-radius: 0 10px 10px 0;
      font-size: 15px;
      font-weight: 500;
      color: var(--beacon-gray-700);
      line-height: 1.5;
    }

    /* NEW: Reasoning Strip - 3 badges */
    .reasoning-strip {
      display: flex;
      gap: 12px;
      margin: 16px 0;
      flex-wrap: wrap;
    }

    .reason-badge {
      display: flex;
      flex-direction: column;
      gap: 4px;
      padding: 12px 16px;
      background: var(--beacon-gray-50);
      border: 1px solid var(--beacon-gray-200);
      border-radius: 12px;
      min-width: 100px;
    }

    .reason-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--beacon-gray-500);
    }

    .reason-value {
      font-size: 16px;
      font-weight: 700;
      color: var(--beacon-navy);
    }

    .reason-value.trend-up { color: var(--beacon-success); }
    .reason-value.trend-down { color: var(--beacon-error); }

    /* Execution Plan Styling */
    .execution-plan {
      margin-top: 20px;
      background: var(--beacon-gray-50);
      border: 1px solid var(--beacon-gray-200);
      border-radius: 16px;
      overflow: hidden;
    }

    .execution-header {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 1px;
      background: var(--beacon-gray-200);
    }

    .execution-header-item {
      background: var(--beacon-white);
      padding: 14px 16px;
    }

    .execution-header-label {
      display: block;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--beacon-gray-500);
      margin-bottom: 4px;
    }

    .execution-header-value {
      font-size: 13px;
      font-weight: 600;
      color: var(--beacon-navy);
      line-height: 1.4;
    }

    .execution-header-sub {
      font-size: 11px;
      color: var(--beacon-gray-500);
      margin-top: 2px;
    }

    .execution-steps {
      padding: 18px 20px;
      background: var(--beacon-white);
      border-top: 1px solid var(--beacon-gray-200);
    }

    .execution-steps-label {
      display: block;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--beacon-blue);
      margin-bottom: 12px;
    }

    .execution-steps-list {
      margin: 0;
      padding-left: 0;
      list-style: none;
      counter-reset: step-counter;
    }

    .execution-steps-list li {
      position: relative;
      padding-left: 32px;
      margin-bottom: 10px;
      font-size: 13px;
      color: var(--beacon-gray-700);
      line-height: 1.5;
      counter-increment: step-counter;
    }

    .execution-steps-list li::before {
      content: counter(step-counter);
      position: absolute;
      left: 0;
      top: 0;
      width: 22px;
      height: 22px;
      background: var(--beacon-blue);
      color: var(--beacon-white);
      font-size: 11px;
      font-weight: 700;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .execution-steps-list li:last-child {
      margin-bottom: 0;
    }

    .execution-measurement {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 14px 20px;
      background: linear-gradient(135deg, rgba(16, 185, 129, 0.08) 0%, rgba(16, 185, 129, 0.04) 100%);
      border-top: 1px solid rgba(16, 185, 129, 0.2);
    }

    .measurement-icon {
      font-size: 18px;
    }

    .measurement-content {
      flex: 1;
    }

    .measurement-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--beacon-success);
      margin-bottom: 2px;
    }

    .measurement-value {
      font-size: 13px;
      font-weight: 600;
      color: var(--beacon-gray-700);
    }

    /* Fallback for plays without execution templates */
    .action-steps {
      margin-top: 20px;
      padding: 16px;
      background: var(--beacon-gray-50);
      border: 1px solid var(--beacon-gray-200);
      border-radius: 12px;
    }

    .steps-label {
      display: block;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--beacon-gray-500);
      margin-bottom: 10px;
    }

    .steps-list {
      margin: 0;
      padding-left: 20px;
      font-size: 14px;
      color: var(--beacon-gray-700);
      line-height: 1.6;
    }

    .steps-list li {
      margin-bottom: 6px;
    }

    .steps-list li:last-child {
      margin-bottom: 0;
    }

    .evidence-list {
      margin: 0;
      padding-left: 20px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      color: var(--beacon-gray-600);
    }

    /* Updated: Action Chart container - now full-width stacked */
    .action-chart {
      display: flex;
      flex-direction: column;
      gap: 16px;
      margin-top: 8px;
      padding: 24px;
      background: linear-gradient(135deg, rgba(59, 130, 246, 0.04) 0%, rgba(16, 185, 129, 0.04) 100%);
      border-radius: 16px;
      border: 1px solid var(--beacon-gray-100);
    }

    /* Chart title as conclusion */
    .chart-conclusion {
      font-size: 17px;
      font-weight: 600;
      color: var(--beacon-navy);
      padding: 12px 16px;
      background: rgba(245, 158, 11, 0.12);
      border-radius: 10px;
      line-height: 1.4;
    }

    .action-chart img {
      width: 100%;
      max-width: 100%;
      border-radius: 14px;
      border: 1px solid var(--beacon-gray-200);
      box-shadow: 0 12px 32px rgba(15, 23, 42, 0.12);
      background: var(--beacon-white);
    }

    .action-chart figcaption {
      font-size: 14px;
      color: var(--beacon-gray-600);
      line-height: 1.6;
    }

    /* NEW: Evidence Chips - data points under chart */
    .evidence-chips {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 4px;
    }

    .evidence-chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      background: var(--beacon-white);
      border: 1px solid var(--beacon-gray-200);
      border-radius: 999px;
      font-size: 12px;
    }

    .chip-label {
      color: var(--beacon-gray-500);
      font-weight: 500;
    }

    .chip-value {
      color: var(--beacon-navy);
      font-weight: 700;
    }

    .chart-glossary {
      margin-top: 12px;
      background: var(--beacon-gray-50);
      border: 1px solid var(--beacon-gray-200);
      border-radius: 10px;
      padding: 12px 16px;
      font-size: 13px;
      color: var(--beacon-gray-600);
    }

    .chart-glossary.inline {
      margin-top: 8px;
    }

    .chart-glossary summary {
      font-weight: 600;
      color: var(--beacon-blue);
      cursor: pointer;
    }

    .chart-glossary ul {
      margin: 10px 0 0;
      padding-left: 18px;
      line-height: 1.5;
    }

    /* Sprint Plan - Timeline Table */
    .sprint-plan {
      background: linear-gradient(180deg, rgba(248, 250, 252, 0.9) 0%, rgba(255, 255, 255, 0.95) 100%);
      border-top: 1px solid var(--beacon-gray-100);
      padding: 56px 72px 64px;
    }

    .sprint-summary {
      display: flex;
      gap: 32px;
      margin-bottom: 32px;
      flex-wrap: wrap;
    }

    .sprint-stat {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .sprint-stat-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--beacon-gray-500);
    }

    .sprint-stat-value {
      font-size: 28px;
      font-weight: 800;
      color: var(--beacon-navy);
    }

    .sprint-table {
      width: 100%;
      border-collapse: collapse;
      background: var(--beacon-white);
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 12px 32px rgba(15, 23, 42, 0.08);
    }

    .sprint-table thead {
      background: var(--beacon-navy);
      color: var(--beacon-white);
    }

    .sprint-table th {
      padding: 16px 20px;
      text-align: left;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .sprint-table tbody tr {
      border-bottom: 1px solid var(--beacon-gray-100);
    }

    .sprint-table tbody tr:last-child {
      border-bottom: none;
    }

    .sprint-table td {
      padding: 16px 20px;
      font-size: 14px;
      color: var(--beacon-gray-700);
      vertical-align: middle;
    }

    .sprint-table .tier-cell {
      font-weight: 700;
      color: var(--beacon-navy);
      white-space: nowrap;
    }

    .sprint-table .tier-cell.primary { background: rgba(59, 130, 246, 0.06); }
    .sprint-table .tier-cell.quick_wins { background: rgba(245, 158, 11, 0.06); }
    .sprint-table .tier-cell.experiments { background: rgba(99, 102, 241, 0.06); }
    .sprint-table .tier-cell.watchlist { background: rgba(107, 114, 128, 0.06); }

    .sprint-table .action-cell {
      font-weight: 600;
      color: var(--beacon-navy);
    }

    .sprint-table .owner-cell {
      color: var(--beacon-gray-600);
    }

    .sprint-table .impact-cell {
      font-weight: 700;
      color: var(--beacon-success);
    }

    .sprint-table .impact-cell.muted {
      color: var(--beacon-gray-400);
      font-weight: 500;
    }

    .tier-badge {
      display: inline-block;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      margin-right: 8px;
    }

    .tier-badge.primary { background: var(--beacon-blue); }
    .tier-badge.quick_wins { background: var(--beacon-amber); }
    .tier-badge.experiments { background: #6366F1; }
    .tier-badge.watchlist { background: var(--beacon-gray-400); }

    /* Tier Explainer - Compact Footer */
    .tier-footer {
      padding: 24px 72px;
      background: var(--beacon-gray-50);
      border-top: 1px solid var(--beacon-gray-100);
      display: flex;
      align-items: center;
      gap: 24px;
      flex-wrap: wrap;
    }

    .tier-footer-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--beacon-gray-500);
    }

    .tier-footer-items {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
    }

    .tier-footer-item {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      color: var(--beacon-gray-600);
    }

    .tier-footer-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
    }

    .tier-footer-dot.primary { background: var(--beacon-blue); }
    .tier-footer-dot.quick_wins { background: var(--beacon-amber); }
    .tier-footer-dot.experiments { background: #6366F1; }
    .tier-footer-dot.watchlist { background: var(--beacon-gray-400); }

    @media (max-width: 980px) {
      section { padding: 48px 28px; }
      .score-layout { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="demo-container">
    <section class="hero">
      <div class="brand-lockup">
        <span class="brand-wordmark">beac<span class="brand-dot">•</span>n</span>
        <span class="brand-pill">{{ story.hero.month_label }}</span>
      </div>
      <h1>Your Next Month Roadmap for {{ brand }}</h1>
      <p class="hero-subheadline">{{ story.hero.subtitle }}</p>
      <div class="hero-grid">
        {% for card in story.hero.cards %}
        <div class="hero-card">
          <h3>{{ card.label }}</h3>
          <div class="hero-value">{{ card.value }}</div>
          <p class="hero-note">{{ card.note }}</p>
        </div>
        {% endfor %}
      </div>
    </section>

    {% if story.seasonal_note and story.seasonal_note.show %}
    <div class="seasonal-banner type-{{ story.seasonal_note.type }}">
      <div class="seasonal-icon">📅</div>
      <div class="seasonal-content">
        <div class="seasonal-title">{{ story.seasonal_note.title }}</div>
        <p class="seasonal-message">{{ story.seasonal_note.message }}</p>
      </div>
    </div>
    {% endif %}

    <section class="score-section">
      <div class="section-kicker">Beacon Health</div>
      <h2 class="section-title">Beacon Score <span class="title-accent">Growth Pulse</span></h2>
      <p class="section-summary">We blend revenue, customer, margin, growth, and LTV signals into a single score so your team knows exactly where to focus.</p>

        <div class="score-layout">
          <div class="score-card">
            <div class="score-value">
              <div class="score-number">{{ story.score.value }}</div>
              <div class="score-tier">{{ story.score.tier }}</div>
            </div>
            {% set trend = story.score.trend|string %}
            {% if trend.startswith('+') %}
              <div class="score-trend">↗︎ {{ trend }} pts vs last month</div>
            {% elif trend.startswith('-') %}
              <div class="score-trend" style="color: var(--beacon-error);">↘︎ {{ trend }} pts vs last month</div>
            {% else %}
              <div class="score-trend" style="color: var(--beacon-gray-500);">→ Stable month over month</div>
            {% endif %}
            <div class="score-summary-card">Operating in {{ story.score.tier }} territory — {{ story.score.summary }}</div>
          </div>

          <div class="score-factors">
            {% for component in story.score.components %}
            <div class="factor-card">
              <div class="factor-metric">
                <span class="factor-name">{{ component.name }}</span>
                <span class="factor-score">{{ component.score }}</span>
              </div>
              <div class="factor-story">
                {% if component.name == 'Revenue Health' %}
                  This month’s revenue momentum drives the roadmap recommendations.
                {% elif component.name == 'Customer Health' %}
                  Repeat patterns signal which lifecycle plays should run now.
                {% elif component.name == 'Margin Health' %}
                  Pricing discipline and bundle strategy help upgrade AOV without blanket discounts.
                {% elif component.name == 'Growth Health' %}
                  Upper-funnel performance determines how hard we can lean into experiments.
                {% else %}
                  LTV potential stays strong when retention plays land on time.
                {% endif %}
              </div>
            </div>
            {% endfor %}
          </div>
        </div>
    </section>

    {% if story.charts %}
    <section>
      <div class="section-kicker">Data Highlights</div>
      <h2 class="section-title">Charts That Set Up The Story</h2>
      <p class="section-summary">Each visualization below powers a recommendation. We attach the most relevant chart to every tier so stakeholders see the evidence at a glance.</p>
      <div class="chart-grid">
        {% for chart in story.charts %}
        <div class="chart-card">
          <span class="chart-tag">{{ chart.title }}</span>
          <div class="chart-figure">
            <img src="{{ chart.path }}" alt="{{ chart.title }}" />
          </div>
          <p class="chart-caption">{{ chart.summary }}</p>
          {% if chart.key == 'customer_segments' %}
          <details class="chart-glossary inline">
            <summary>What the value tiers mean</summary>
            <ul>
              <li><strong>Champions</strong>: 3+ orders in the last 30 days.</li>
              <li><strong>Loyal</strong>: 3+ orders with activity in the last 90 days.</li>
              <li><strong>New</strong>: First purchase within the last month.</li>
              <li><strong>Developing</strong>: Multi-buyers still building habits.</li>
              <li><strong>At Risk</strong>: 2+ orders but inactive for 60+ days.</li>
              <li><strong>Lost</strong>: No purchase in the last 90+ days.</li>
            </ul>
          </details>
          {% endif %}
        </div>
        {% endfor %}
      </div>
    </section>
    {% endif %}

    <section class="actions-section">
      <div class="section-kicker">Action Engine</div>
      <h2 class="section-title">Recommendations With Embedded Evidence</h2>
      <p class="section-summary">We rank plays by impact and confidence. Every card pairs the narrative with the chart that triggered the recommendation.</p>

      {% for tier in story.tiers %}
      <div class="tier-section {{ tier.id }}">
        <div class="tier-header">
          <h3 class="tier-title">
            <span class="tier-pill {{ tier.id }}">{{ tier.badge }}</span>
            {{ tier.title }}
          </h3>
          <p class="tier-description">{{ tier.description }}</p>
        </div>
        <div class="actions-grid">
          {% for action in tier.actions %}
          <article class="action-card">
            <div>
              <!-- Header: Title + Signal Strength -->
              <div class="action-header">
                <h3 class="action-title">{{ action.title }}</h3>
                <span class="signal-badge {{ action.signal_strength | lower | replace(' ', '-') }}">{{ action.signal_strength }}</span>
              </div>

              <!-- Tier Reason: Why this action is in this tier -->
              {% if action.tier_reason %}
              <p class="tier-reason">{{ action.tier_reason }}</p>
              {% endif %}

              <!-- Why Now: One-liner tied to chart -->
              {% if action.why_now %}
              <p class="why-now">{{ action.why_now }}</p>
              {% else %}
              <p class="why-now">{{ action.narrative }}</p>
              {% endif %}

              <!-- Reasoning Strip: Target + 28-Day Impact -->
              <div class="reasoning-strip">
                <div class="reason-badge">
                  <span class="reason-label">{{ action.reasoning.label_1 | default('Target') }}</span>
                  <span class="reason-value">{{ action.reasoning.value_1 | default(action.audience_value) }}</span>
                </div>
                <div class="reason-badge">
                  <span class="reason-label">{{ action.reasoning.label_2 | default('28-Day Impact') }}</span>
                  <span class="reason-value">{{ action.reasoning.value_2 | default(action.impact_value) }}</span>
                </div>
              </div>

              <!-- Execution Plan -->
              {% if action.execution %}
              <div class="execution-plan">
                <!-- Structured Header -->
                <div class="execution-header">
                  <div class="execution-header-item">
                    <span class="execution-header-label">Audience</span>
                    <span class="execution-header-value">{{ action.execution.audience.size }} customers</span>
                    <span class="execution-header-sub">{{ action.execution.audience.segment_path | default('segment.csv') }}</span>
                  </div>
                  <div class="execution-header-item">
                    <span class="execution-header-label">Channel</span>
                    <span class="execution-header-value">{{ action.execution.channel.primary | title }}{% if action.execution.channel.secondary %} + {{ action.execution.channel.secondary | title }}{% endif %}</span>
                    <span class="execution-header-sub">{{ action.execution.channel.platform }}</span>
                  </div>
                  <div class="execution-header-item">
                    <span class="execution-header-label">Sequence</span>
                    <span class="execution-header-value">{{ action.execution.sequence.touches }} touches</span>
                    <span class="execution-header-sub">{{ action.execution.sequence.timing | join(' → ') }}</span>
                  </div>
                  <div class="execution-header-item">
                    <span class="execution-header-label">Offer</span>
                    <span class="execution-header-value">{{ action.execution.offer.structure }}</span>
                    <span class="execution-header-sub">Cap: {{ action.execution.offer.cap }}</span>
                  </div>
                </div>

                <!-- Step-by-Step Instructions -->
                <div class="execution-steps">
                  <span class="execution-steps-label">Execution Steps</span>
                  <ol class="execution-steps-list">
                    {% for step in action.execution.steps %}
                    <li>{{ step }}</li>
                    {% endfor %}
                  </ol>
                </div>

                <!-- Measurement Footer -->
                <div class="execution-measurement">
                  <span class="measurement-icon">📊</span>
                  <div class="measurement-content">
                    <span class="measurement-label">Success Metric</span>
                    <span class="measurement-value">{{ action.execution.measurement.kpi }}: {{ action.execution.measurement.target }} within {{ action.execution.measurement.window_days }} days ({{ action.execution.measurement.holdout_pct }}% holdout)</span>
                  </div>
                </div>
              </div>
              {% elif action.steps %}
              <!-- Fallback for plays without execution templates -->
              <div class="action-steps">
                <span class="steps-label">What you'll change</span>
                <ol class="steps-list">
                  {% for step in action.steps[:3] %}
                  <li>{{ step }}</li>
                  {% endfor %}
                </ol>
              </div>
              {% endif %}
            </div>

            <!-- Right column: Chart + Evidence -->
            <figure class="action-chart">
              {% set chart = action.charts[0] if action.charts %}
              {% if chart %}
                <!-- Chart conclusion as title -->
                <div class="chart-conclusion">{{ action.chart_conclusion | default(chart.title) }}</div>
                <img src="{{ chart.path }}" alt="{{ chart.title }}" />

                <!-- Evidence Chips -->
                {% if action.evidence_chips %}
                <div class="evidence-chips">
                  {% for chip in action.evidence_chips %}
                  <span class="evidence-chip">
                    <span class="chip-label">{{ chip.label }}</span>
                    <span class="chip-value">{{ chip.value }}</span>
                  </span>
                  {% endfor %}
                </div>
                {% else %}
                <div class="evidence-chips">
                  <span class="evidence-chip">
                    <span class="chip-label">Window</span>
                    <span class="chip-value">L28</span>
                  </span>
                  <span class="evidence-chip">
                    <span class="chip-label">Confidence</span>
                    <span class="chip-value">{{ action.confidence }}</span>
                  </span>
                </div>
                {% endif %}
              {% else %}
                <div class="chart-conclusion">Evidence-based recommendation</div>
                <div class="chart-caption" style="padding: 24px; background: var(--beacon-gray-50); border-radius: 12px; text-align: center;">
                  This play is driven by behavioral patterns rather than time-window KPIs.
                </div>
              {% endif %}
            </figure>
          </article>
          {% endfor %}
        </div>
      </div>
      {% endfor %}
    </section>

    {% if story.sprint_plan and story.sprint_plan.tiers %}
    <section class="sprint-plan">
      <div class="section-kicker">Action Summary</div>
      <h2 class="section-title">Monthly Action Plan</h2>

      <!-- Summary Stats -->
      <div class="sprint-summary">
        <div class="sprint-stat">
          <span class="sprint-stat-label">Total Opportunity</span>
          <span class="sprint-stat-value">{{ story.sprint_plan.total_opportunity }}</span>
        </div>
        <div class="sprint-stat">
          <span class="sprint-stat-label">Actions This Month</span>
          <span class="sprint-stat-value">{{ story.sprint_plan.total_actions }}</span>
        </div>
      </div>

      <!-- Action Summary Table -->
      <table class="sprint-table">
        <thead>
          <tr>
            <th>Tier</th>
            <th>Action</th>
            <th>Owner</th>
            <th>28-Day Impact</th>
          </tr>
        </thead>
        <tbody>
          {% for tier in story.sprint_plan.tiers %}
            {% for action in tier.actions %}
            <tr>
              {% if loop.first %}
              <td class="tier-cell {{ tier.tier }}" rowspan="{{ tier.actions|length }}">
                <span class="tier-badge {{ tier.tier }}"></span>
                {{ tier.label }}
              </td>
              {% endif %}
              <td class="action-cell">{{ action.title }}</td>
              <td class="owner-cell">{{ action.owner }}</td>
              <td class="impact-cell {% if action.impact == '—' %}muted{% endif %}">{{ action.impact }}</td>
            </tr>
            {% endfor %}
          {% endfor %}
        </tbody>
      </table>
    </section>
    {% endif %}

    <!-- Compact Tier Legend Footer -->
    <div class="tier-footer">
      <span class="tier-footer-label">Tier Guide</span>
      <div class="tier-footer-items">
        <span class="tier-footer-item">
          <span class="tier-footer-dot primary"></span>
          <strong>Primary:</strong> Strong evidence, launch first
        </span>
        <span class="tier-footer-item">
          <span class="tier-footer-dot quick_wins"></span>
          <strong>Quick Wins:</strong> Lower effort, run alongside primaries
        </span>
        <span class="tier-footer-item">
          <span class="tier-footer-dot experiments"></span>
          <strong>Experiments:</strong> Promising, test at small scale
        </span>
        <span class="tier-footer-item">
          <span class="tier-footer-dot watchlist"></span>
          <strong>Watchlist:</strong> Needs more data before committing
        </span>
      </div>
    </div>

  </div>
</body>
</html>
